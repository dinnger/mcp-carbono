{
  "name": "mcp-carbono",
  "version": "1.0.0",
  "description": "stdio MCP server that generates images for the AI by rendering HTML/Tailwind to PNG.",
  "type": "module",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "image-generation",
    "puppeteer",
    "tailwindcss",
    "daisyui",
    "stdio"
  ],
  "license": "MIT",
  "bin": {
    "mcp-carbono": "index.ts"
  },
  "files": [
    "index.ts",
    "tools.ts",
    "types.ts",
    "tools/",
    "carbono/",
    "util/",
    "scripts/",
    "puppeteer.cache.cjs",
    ".puppeteerrc.cjs",
    "tsconfig.json",
    "README.md"
  ],
  "engines": {
    "bun": ">=1.0.0"
  },
  "scripts": {
    "start": "bun run index.ts",
    "browser:install": "node scripts/install-browser.mjs",
    "postinstall": "node scripts/install-browser.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@tailwindcss/cli": "^4.0.0",
    "daisyui": "^5.0.0",
    "puppeteer": "^23.0.0",
    "tailwindcss": "^4.0.0",
    "winston": "^3.19.0",
    "zod": "^3.25.28"
  },
  "devDependencies": {
    "@types/node": "^25.5.0"
  }
}
